# 阿里云百炼 API Key。仅保存在本地 .env.local，不要提交。
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 从 aliyun-cosyvoice-demo 迁移的 CosyVoice 配置。
COSYVOICE_MODEL=cosyvoice-v3-flash
COSYVOICE_DEFAULT_VOICE=longanhuan_v3
DASHSCOPE_WORKSPACE_ID=llm-9okku7exfrpx4pkf
DASHSCOPE_REGION=cn-beijing
REWRITE_MODEL=qwen-plus
ASR_MODEL=fun-asr-realtime
VOICEPRINT_THRESHOLD=0.6
# 使用 xfyun 接入在线声纹；需要本地演示回退时改为 local。
VOICEPRINT_PROVIDER=xfyun
XFYUN_APP_ID=your-xfyun-app-id
XFYUN_API_KEY=your-xfyun-api-key
XFYUN_API_SECRET=your-xfyun-api-secret
XFYUN_VOICEPRINT_URL=https://api.xf-yun.com/v1/private/s1aa729d0
XFYUN_VOICEPRINT_GROUP_ID=tsy_staff

# Demo 服务地址。
HOST=127.0.0.1
PORT=4173
